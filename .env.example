# OSINT console environment. Copy to .env and fill in what you have:
#   cp .env.example .env
# EVERY key is optional — the platform boots and shows aircraft, vessels,
# quakes, and the dark basemap with this file completely empty (CLAUDE.md
# "layers that must always work without any API key").

# ── Visual / runtime config exposed to the browser ──────────────────────────
# Cesium ion token (free Community tier) — only needed for OSM 3D Buildings.
CESIUM_ION_TOKEN=
# Google Photorealistic 3D Tiles feature flag (needs ion token; off = free).
ENABLE_GOOGLE_3D=false
CLASSIFICATION=UNCLAS
BUILD_ID=dev

# ── Upstream keys (all optional; layers degrade gracefully when unset) ──────
# OpenSky OAuth2 client-credentials. UNSET still works — the breadth tier
# falls back to anonymous /states/all (~400 credits/day per source IP).
# Creds raise the daily budget and unlock the cred-gated correlate ingest.
OPENSKY_CLIENT_ID=
OPENSKY_CLIENT_SECRET=
# Keyless full-feed ADS-B — open global readsb/tar1090 instances that serve
# their FULL aircraft.json with no key (the "tar1090 way"). Unioned with OpenSky
# (measured ~14k vs ~12.7k OpenSky-only). Pulled ONE feed per cycle, round-robin,
# every ADSB_FEED_INTERVAL_S so no single host is rate-limited. Add your own
# ultrafeeder/tar1090 URL here to fold in its coverage.
ADSB_FEED_URLS=https://globe.theairtraffic.com/data/aircraft.json,https://skylink.hpradar.com/data/aircraft.json
ADSB_FEED_INTERVAL_S=30
# AISStream.io key — global live vessel WS layer (Digitraffic Baltic works
# without it).
AISSTREAM_KEY=
# NASA FIRMS MAP_KEY — active-fire layer.
FIRMS_MAP_KEY=
# Global Fishing Watch token — vessel identity enrichment / dark vessels.
GFW_TOKEN=
# ACLED conflict events (key + registered email, both required together).
ACLED_KEY=
ACLED_EMAIL=
# Cloudflare Radar token — internet-outage annotations.
CLOUDFLARE_TOKEN=
# Copernicus Data Space (Sentinel) — reserved for imagery tasking.
CDSE_CLIENT_ID=
CDSE_CLIENT_SECRET=
GMAPS_KEY=
OPENAIP_KEY=

# ── Server ───────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
LOG_LEVEL=info
CORS_ORIGINS=http://localhost:8080
# When set, every REST + WS route requires X-API-Key (or ?key=) to match.
# The web bundle must then be built with VITE_API_KEY set to the same value.
API_KEY=
# Disk tile cache root — safe to delete anytime, refills on demand.
TILE_CACHE_DIR=./data/tilecache

# ── MCP server + local AI (Ollama) ───────────────────────────────────────────
API_BASE=http://localhost:8000
OLLAMA_HOST=http://localhost:11434
# "" → auto-detect the smallest installed model.
OLLAMA_MODEL=

# ── DeepSeek (OpenAI-compatible) — primary reasoning backend ─────────────────
# Used by deep_analyze + the news debias/fact-check engine; falls back to
# Ollama, then to raw structured data, when unset/unreachable. When blank,
# app.llm reads the key + base from the user's opencode config
# (~/.config/opencode/opencode.jsonc → provider.deepseek.options).
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=
# Model ids per task tier (fast=extraction/classification, reason=judgement).
DEEPSEEK_MODEL_FAST=deepseek-chat
DEEPSEEK_MODEL_REASON=deepseek-reasoner

# ── News debias / fact-check engine ──────────────────────────────────────────
NEWS_ENABLED=true
NEWS_REFRESH_SEC=600
NEWS_MAX_ITEMS=400

# ── Historical playback (3D replay/scrub) ────────────────────────────────────
HISTORY_ENABLED=true
HISTORY_DB_PATH=./data/history.db
HISTORY_RETENTION_HOURS=48
